# --- Base de données PostgreSQL ---
POSTGRES_USER=skydive
POSTGRES_PASSWORD=changeme
POSTGRES_DB=skydivemediahub
DATABASE_URL=postgresql://skydive:changeme@db:5432/skydivemediahub

# --- Stockage vidéo ---
# Chemin sur le PC hôte vers le HDD SATA dédié aux vidéos
# Exemple Linux : /mnt/hdd_videos
VIDEO_STORAGE_PATH=/mnt/hdd_videos

# --- Authentification JWT ---
# Clé secrète pour signer les tokens JWT. Générer avec : openssl rand -hex 32
SECRET_KEY=change-me-in-production

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=changeme
